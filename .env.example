# ============================================================
# Copie para .env e preencha com seus valores reais
# NUNCA commite o .env no git (já está no .gitignore)
# ============================================================

# Banco de dados PostgreSQL (Railway fornece automaticamente)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Ambiente (development | production)
NODE_ENV=development

# Porta do servidor (Railway define automaticamente em produção)
PORT=3001

# URL do frontend (usado para CORS em produção)
# Exemplo: https://dashboard-refugo.up.railway.app
FRONTEND_URL=http://localhost:3000

# Segredo para geração dos tokens JWT — ALTERE para uma string longa e aleatória em produção!
# Gere uma com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=mude-para-uma-chave-secreta-longa-e-aleatoria-em-producao
